---
import siteData from '../data/site.json';

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-about">
        <a href="/" class="logo-container">
          <div class="logo-icon" style="width: 30px; height: 30px;">
            <img src={siteData.logo} alt={`${siteData.name} Logo`} width="30" height="30" />
          </div>
          <div class="logo-text">
            <span class="text-gradient-dual" style="font-size: 1.2rem;">{siteData.name}</span>
            <span class="logo-sub" style="font-size: 0.6rem; letter-spacing: 1px;">{siteData.subName}</span>
          </div>
        </a>
        <p>{siteData.fullName} is part of the Enterprise & Industrial System (EIS) Expertise Group, Bachelor of Information Systems Study Program, Faculty of Industrial Engineering, Telkom University.</p>
      </div>

      <div>
        <h4 class="footer-title">Quick Links</h4>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/event">Event</a></li>
          <li><a href="/structure">Structure</a></li>
          <li><a href="/news">News</a></li>
        </ul>
      </div>

      <div>
        <h4 class="footer-title">Contact & Location</h4>
        <ul class="footer-links" style="margin-bottom: 20px;">
          <li><i class="fa-solid fa-location-dot" style="margin-right: 8px; color: var(--accent-red);"></i> {siteData.contact.location}</li>
          <li><i class="fa-solid fa-university" style="margin-right: 8px; color: var(--accent-red);"></i> {siteData.contact.university}</li>
          <li><i class="fa-solid fa-envelope" style="margin-right: 8px; color: var(--accent-cyan);"></i> {siteData.contact.email}</li>
        </ul>
        <h4 class="footer-title" style="margin-bottom: 12px; font-size: 0.95rem;">Follow Our Social Media</h4>
        <div class="footer-socials">
          <a href={siteData.socials.instagram} target="_blank" rel="noopener noreferrer" class="footer-social-btn" title={`Instagram @${siteData.name.toLowerCase()}researchlab`}>
            <i class="fa-brands fa-instagram"></i>
          </a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} {siteData.fullName}. All Rights Reserved.</p>
      <p>Designed with <i class="fa-solid fa-heart" style="color: var(--accent-red);"></i> in Telkom University</p>
    </div>
  </div>
</footer>
