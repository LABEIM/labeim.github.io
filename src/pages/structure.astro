---

<Layout title="Organizational Structure - EIM Research Lab">
  <section class="page-header" style="padding-top: 150px; padding-bottom: 50px;">
    <div class="container">
      <div class="page-header-content">
        <h1>Organizational <span class="text-gradient-cyan">Structure</span></h1>
        <p style="margin-top: 15px; color: var(--text-secondary);">Meet the EIM laboratory assistants in each division.</p>
      </div>
    </div>
  </section>

  <section class="section-padding" id="structure">
    <div class="container">
      <div class="filter-container" id="filter-tabs">
        <button class="filter-tab active" data-filter="all">All Divisions</button>
        <button class="filter-tab" data-filter="core">Core</button>
        <button class="filter-tab" data-filter="research">Research</button>
        <button class="filter-tab" data-filter="pku">PKU</button>
        <button class="filter-tab" data-filter="competition">Competition</button>
        <button class="filter-tab" data-filter="media">Media & PR</button>
        <button class="filter-tab" data-filter="community">Community Service</button>
      </div>

      <div class="member-grid" id="member-grid">
        {initialMembers.map((member, idx) => (
          <div 
            class={`member-card glass-panel member-card-item div-${member.division}`} 
            data-division={member.division}
            style={`animation-delay: ${idx * 0.04}s`}
          >
            <div class="member-avatar-wrapper">
              <div class="member-avatar" style={member.image ? "background: transparent;" : ""}>
                {member.image ? (
                  <img
                    src={member.image}
                    alt={member.name}
                    style={{
                      width: '100%', height: '100%', objectFit: 'cover', borderRadius: 'inherit', display: 'block',
                      transform: member.scale ? `scale(${member.scale})` : 'none',
                      transformOrigin: member.position || 'center'
                    }}
                  />
                ) : (
                  <i class="fa-solid fa-user" style="font-size: 2.5rem; opacity: 0.5;"></i>
                )}
              </div>
            </div>
            <div class="member-info">
              <h3>{member.name}</h3>
              <div class="member-role">{member.role}</div>
              <span class="member-div">
                {member.division === 'core' && 'CORE'}
                {member.division === 'research' && 'RESEARCH'}
                {member.division === 'pku' && 'PKU'}
                {member.division === 'competition' && 'COMPETITION'}
                {member.division === 'media' && 'MEDIA & PR'}
                {member.division === 'community' && 'COMMUNITY'}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const tabs = document.querySelectorAll('#filter-tabs .filter-tab');
  const members = document.querySelectorAll('#member-grid .member-card-item');

  function applyFilter(filterVal: string) {
    // Update active tab class
    tabs.forEach(tab => {
      if (tab.getAttribute('data-filter') === filterVal) {
        tab.classList.add('active');
      } else {
        tab.classList.remove('active');
      }
    });

    // Show/hide members
    members.forEach(member => {
      const card = member as HTMLElement;
      const division = card.getAttribute('data-division');
      if (filterVal === 'all' || division === filterVal) {
        card.style.display = 'flex';
      } else {
        card.style.display = 'none';
      }
    });
  }

  // Handle click on tabs
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const filterVal = tab.getAttribute('data-filter') || 'all';
      applyFilter(filterVal);
      
      // Update URL
      const newUrl = `${window.location.protocol}//${window.location.host}${window.location.pathname}?div=${filterVal}`;
      window.history.pushState({ path: newUrl }, '', newUrl);
    });
  });

  // Handle initial load from search params
  window.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    const divParam = params.get('div') || params.get('divisi') || 'all';
    // Map Indonesian URL queries if someone bookmarked them
    let mappedParam = divParam;
    if (divParam === 'inti') mappedParam = 'core';
    else if (divParam === 'riset') mappedParam = 'research';
    else if (divParam === 'lomba') mappedParam = 'competition';
    else if (divParam === 'medhum') mappedParam = 'media';
    else if (divParam === 'pengmas') mappedParam = 'community';
    
    applyFilter(mappedParam);
  });
</script>
