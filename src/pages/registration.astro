---
import Layout from '../layouts/Layout.astro';
import registrationConfig from '../data/registration.json';
import divisions from '../data/divisions.json';
---

<Layout title="Assistant Lab Registration - EIM Research Lab">
  <section class="page-header" style="padding-top: 150px; padding-bottom: 50px;">
    <div class="container">
      <div class="page-header-content">
        <div class="hero-tag"><span></span> Assistant Recruitment</div>
        <h1>Assistant <span class="text-gradient-cyan">Lab Registration</span></h1>
        <p class="hero-desc">Join us and become a part of EIM Research Lab. Develop your potential in IT infrastructure, networks, and technology research.</p>
      </div>
    </div>
  </section>

  <section class="section-padding" id="registration">
    <div class="container">
      <div class="registration-form-container glass-panel" id="registration-container" data-deadline={registrationConfig.deadline} style="max-width: 850px; margin: 0 auto; border-top: 3px solid var(--accent-cyan);">
        <div class="registration-header" style="text-align: center; margin-bottom: 30px;">
          <h2 style="font-size: 2rem; margin-bottom: 10px;">{registrationConfig.title}</h2>
          <p style="color: var(--text-secondary);">{registrationConfig.subtitle}</p>
        </div>

        {/* Status Alerts */}
        <div id="status-alert-error" style="display: none; backgroundColor: rgba(255,0,0,0.1); color: #ff6b6b; padding: 12px; border-radius: 6px; margin-bottom: 20px; text-align: center; border: 1px solid rgba(255,107,107,0.3);"></div>
        <div id="status-alert-success" style="display: none; backgroundColor: rgba(0,255,0,0.1); color: #20c997; padding: 15px; border-radius: 6px; margin-bottom: 20px; text-align: center; border: 1px solid rgba(32,201,151,0.3);"></div>

        {/* Countdown Timer */}
        <div class="registration-timer" id="registration-timer">
          <div class="timer-block">
            <div id="timer-days" style="font-size: 1.5rem; font-weight: bold; color: var(--text-primary);">0</div>
            <div style="font-size: 0.8rem; color: var(--text-secondary);">Days</div>
          </div>
          <div class="timer-block">
            <div id="timer-hours" style="font-size: 1.5rem; font-weight: bold; color: var(--text-primary);">0</div>
            <div style="font-size: 0.8rem; color: var(--text-secondary);">Hours</div>
          </div>
          <div class="timer-block">
            <div id="timer-minutes" style="font-size: 1.5rem; font-weight: bold; color: var(--text-primary);">0</div>
            <div style="font-size: 0.8rem; color: var(--text-secondary);">Minutes</div>
          </div>
          <div class="timer-block">
            <div id="timer-seconds" style="font-size: 1.5rem; font-weight: bold; color: var(--accent-red);">0</div>
            <div style="font-size: 0.8rem; color: var(--text-secondary);">Seconds</div>
          </div>
        </div>

        {/* Expired Message */}
        <div id="registration-expired" style="display: none; text-align: center; padding: 40px 20px; background-color: var(--bg-card); border-radius: 10px; border: 1px solid var(--border-color);">
          <i class="fa-solid fa-clock-rotate-left" style="font-size: 3rem; color: var(--text-muted); margin-bottom: 15px;"></i>
          <h3 style="font-size: 1.5rem; margin-bottom: 10px; color: var(--text-primary);">Registration Period Ended</h3>
          <p style="color: var(--text-secondary);">{registrationConfig.closedMessage}</p>
        </div>

        {/* Registration Form */}
        <form id="pendaftaran-form">
          {/* Section 1: Data Diri */}
          <div class="form-section-title" style="margin-top: 20px; margin-bottom: 15px; font-size: 1.2rem; font-weight: bold; color: var(--accent-cyan); border-bottom: 1px solid var(--border-color); padding-bottom: 8px;">
            <i class="fa-solid fa-user" style="margin-right: 8px;"></i> 1. Personal Identity
          </div>

          <div class="form-group">
            <label for="nama_lengkap">Full Name <span style="color: var(--accent-red);">*</span></label>
            <input type="text" class="form-control" id="nama_lengkap" placeholder="Your full name" required />
          </div>

          <div class="form-row" style="margin-top: 15px;">
            <div class="form-group">
              <label for="nim">Student ID (NIM) <span style="color: var(--accent-red);">*</span></label>
              <input type="text" class="form-control" id="nim" placeholder="Example: 1202210001" pattern="[0-9]+" required />
            </div>
            <div class="form-group">
              <label for="angkatan">Student Year (Angkatan) <span style="color: var(--accent-red);">*</span></label>
              <select class="form-control" id="angkatan" required>
                <option value="" disabled selected>Select Year</option>
                <option value="2022">2022</option>
                <option value="2023">2023</option>
                <option value="2024">2024</option>
                <option value="2025">2025</option>
              </select>
            </div>
          </div>

          <div class="form-row" style="margin-top: 15px;">
            <div class="form-group">
              <label for="email">Email Address <span style="color: var(--accent-red);">*</span></label>
              <input type="email" class="form-control" id="email" placeholder="name@domain.com" required />
            </div>
            <div class="form-group">
              <label for="nomor_telp">Phone / WhatsApp Number <span style="color: var(--accent-red);">*</span></label>
              <input type="tel" class="form-control" id="nomor_telp" placeholder="Example: 081234567890" pattern="[0-9]+" required />
            </div>
          </div>

          {/* Section 2: Pemilihan Divisi */}
          <div class="form-section-title" style="margin-top: 35px; margin-bottom: 15px; font-size: 1.2rem; font-weight: bold; color: var(--accent-cyan); border-bottom: 1px solid var(--border-color); padding-bottom: 8px;">
            <i class="fa-solid fa-layer-group" style="margin-right: 8px;"></i> 2. Division Selection & Motivation
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="divisi_1">Chosen Division 1 (Primary Choice) <span style="color: var(--accent-red);">*</span></label>
              <select class="form-control" id="divisi_1" required>
                <option value="" disabled selected>Select Division 1</option>
                {divisions.map(div => (
                  <option value={div.registrationValue}>{div.registrationLabel}</option>
                ))}
              </select>
            </div>
            <div class="form-group">
              <label for="divisi_2">Chosen Division 2 (Secondary Choice) <span style="color: var(--accent-red);">*</span></label>
              <select class="form-control" id="divisi_2" required>
                <option value="" disabled selected>Select Division 2</option>
                {divisions.map(div => (
                  <option value={div.registrationValue}>{div.registrationLabel}</option>
                ))}
              </select>
            </div>
          </div>

          <div class="form-group" style="margin-top: 15px;">
            <label for="alasan_divisi_1">Reason for Choosing Division 1 <span style="color: var(--accent-red);">*</span></label>
            <textarea class="form-control" id="alasan_divisi_1" rows="3" placeholder="Explain your motivation and skill background for Division 1..." required></textarea>
          </div>

          <div class="form-group" style="margin-top: 15px;">
            <label for="alasan_divisi_2">Reason for Choosing Division 2 <span style="color: var(--accent-red);">*</span></label>
            <textarea class="form-control" id="alasan_divisi_2" rows="3" placeholder="Explain your motivation and skill background for Division 2..." required></textarea>
          </div>

          {/* Dynamic Portfolio MedHum Link (Shows if Medhum is chosen in Division 1 or Division 2) */}
          <div class="form-group" id="container-medhum-porto" style="display: none; margin-top: 15px; background: rgba(163, 7, 186, 0.08); padding: 15px; border-radius: 8px; border: 1px solid rgba(163, 7, 186, 0.3);">
            <label for="portofolio_medhum" style="color: #e879f9; font-weight: bold;">
              <i class="fa-solid fa-palette" style="margin-right: 6px;"></i> MedHum Portfolio Link <span style="color: var(--accent-red);">*</span>
            </label>
            <input type="url" class="form-control" id="portofolio_medhum" placeholder="https://behance.net/username or https://drive.google.com/..." />
            <small style="color: var(--text-secondary); display: block; margin-top: 5px;">Since you selected MedHum, please provide a public URL link to your design / video portfolio.</small>
          </div>

          <div class="form-group" style="margin-top: 15px;">
            <label for="bersedia_dipindah">Willing to be moved to another division if needed? <span style="color: var(--accent-red);">*</span></label>
            <select class="form-control" id="bersedia_dipindah" required>
              <option value="" disabled selected>Select Preference</option>
              <option value="Ya">Ya (Yes)</option>
              <option value="Tidak">Tidak (No)</option>
            </select>
          </div>

          {/* Section 3: Berkas Pendaftaran */}
          <div class="form-section-title" style="margin-top: 35px; margin-bottom: 15px; font-size: 1.2rem; font-weight: bold; color: var(--accent-cyan); border-bottom: 1px solid var(--border-color); padding-bottom: 8px;">
            <i class="fa-solid fa-folder-open" style="margin-right: 8px;"></i> 3. Document Uploads (PDF / Images)
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="file_ksm">Kartu Studi Mahasiswa (KSM) <span style="font-size: 0.8rem; color: var(--text-secondary);">(Max 2MB)</span> <span style="color: var(--accent-red);">*</span></label>
              <input type="file" class="form-control" id="file_ksm" accept=".pdf,.png,.jpg,.jpeg" required />
            </div>
            <div class="form-group">
              <label for="file_khs">Kartu Hasil Studi (KHS) <span style="font-size: 0.8rem; color: var(--text-secondary);">(Max 2MB)</span> <span style="color: var(--accent-red);">*</span></label>
              <input type="file" class="form-control" id="file_khs" accept=".pdf,.png,.jpg,.jpeg" required />
            </div>
          </div>

          <div class="form-row" style="margin-top: 15px;">
            <div class="form-group">
              <label for="file_ml">Motivation Letter (ML) <span style="font-size: 0.8rem; color: var(--text-secondary);">(Max 2MB)</span> <span style="color: var(--accent-red);">*</span></label>
              <input type="file" class="form-control" id="file_ml" accept=".pdf,.png,.jpg,.jpeg" required />
            </div>
            <div class="form-group">
              <label for="file_cv">Curriculum Vitae (CV) <span style="font-size: 0.8rem; color: var(--text-secondary);">(Max 3MB)</span> <span style="color: var(--accent-red);">*</span></label>
              <input type="file" class="form-control" id="file_cv" accept=".pdf,.png,.jpg,.jpeg" required />
            </div>
          </div>

          <div class="form-group" style="margin-top: 15px;">
            <label for="file_pi">Pakta Integritas (PI) <span style="font-size: 0.8rem; color: var(--text-secondary);">(Max 2MB)</span> <span style="color: var(--accent-red);">*</span></label>
            <input type="file" class="form-control" id="file_pi" accept=".pdf,.png,.jpg,.jpeg" required />
            <small style="color: var(--text-secondary); display: block; margin-top: 5px;">Upload signed Integrity Pact document.</small>
          </div>

          <div class="form-actions" style="justify-content: center; margin-top: 40px;">
            <button type="submit" id="submit-btn" class="btn btn-primary" style="width: 100%; max-width: 320px; padding: 14px; font-size: 1.1rem;">
              <span id="btn-text">Submit Registration <i class="fa-solid fa-paper-plane" style="margin-left: 8px;"></i></span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Registration deadline setup
  const container = document.getElementById('registration-container');
  const deadlineStr = container?.getAttribute('data-deadline') || "2026-08-17T23:59:59";
  const DEADLINE = new Date(deadlineStr).getTime();
  
  const timerContainer = document.getElementById('registration-timer');
  const expiredContainer = document.getElementById('registration-expired');
  const formElement = document.getElementById('pendaftaran-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text');

  const daysEl = document.getElementById('timer-days');
  const hoursEl = document.getElementById('timer-hours');
  const minutesEl = document.getElementById('timer-minutes');
  const secondsEl = document.getElementById('timer-seconds');

  const alertError = document.getElementById('status-alert-error') as HTMLElement;
  const alertSuccess = document.getElementById('status-alert-success') as HTMLElement;

  const div1Select = document.getElementById('divisi_1') as HTMLSelectElement;
  const div2Select = document.getElementById('divisi_2') as HTMLSelectElement;
  const medhumPortoContainer = document.getElementById('container-medhum-porto') as HTMLElement;
  const medhumPortoInput = document.getElementById('portofolio_medhum') as HTMLInputElement;

  // 1. Conditional MedHum Portfolio Input Visibility
  const toggleMedhumPorto = () => {
    const val1 = div1Select?.value || '';
    const val2 = div2Select?.value || '';
    if (val1 === 'Medhum' || val2 === 'Medhum') {
      medhumPortoContainer.style.display = 'block';
      medhumPortoInput.required = true;
    } else {
      medhumPortoContainer.style.display = 'none';
      medhumPortoInput.required = false;
      medhumPortoInput.value = '';
    }
  };

  div1Select?.addEventListener('change', toggleMedhumPorto);
  div2Select?.addEventListener('change', toggleMedhumPorto);

  // 2. Countdown timer logic
  const timer = setInterval(() => {
    const now = new Date().getTime();
    const distance = DEADLINE - now;

    if (distance < 0) {
      clearInterval(timer);
      if (timerContainer) timerContainer.style.display = 'none';
      if (formElement) formElement.style.display = 'none';
      if (expiredContainer) expiredContainer.style.display = 'block';
    } else {
      if (daysEl) daysEl.innerText = String(Math.floor(distance / (1000 * 60 * 60 * 24)));
      if (hoursEl) hoursEl.innerText = String(Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60)));
      if (minutesEl) minutesEl.innerText = String(Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60)));
      if (secondsEl) secondsEl.innerText = String(Math.floor((distance % (1000 * 60)) / 1000));
    }
  }, 1000);

  // Helper function to read file to base64 with custom max MB limit per document type
  const readFileAsBase64 = (
    fileInput: HTMLInputElement,
    maxMb: number = 2,
    documentLabel: string = 'File'
  ): Promise<{ base64: string, fileName: string, mimeType: string } | null> => {
    return new Promise((resolve, reject) => {
      const file = fileInput.files?.[0];
      if (!file) {
        resolve(null);
        return;
      }
      
      // Limit file size based on document type
      if (file.size > maxMb * 1024 * 1024) {
        reject(new Error(`${documentLabel} (${file.name}) exceeds the ${maxMb}MB size limit.`));
        return;
      }

      const reader = new FileReader();
      reader.onload = () => {
        resolve({
          base64: reader.result as string,
          fileName: file.name,
          mimeType: file.type || 'application/octet-stream'
        });
      };
      reader.onerror = () => reject(new Error(`Failed to read file ${file.name}.`));
      reader.readAsDataURL(file);
    });
  };

  // 3. Form submission logic
  formElement?.addEventListener('submit', async (e) => {
    e.preventDefault();
    alertError.style.display = 'none';
    alertSuccess.style.display = 'none';

    const nama_lengkap = (document.getElementById('nama_lengkap') as HTMLInputElement).value;
    const nim = (document.getElementById('nim') as HTMLInputElement).value;
    const angkatan = (document.getElementById('angkatan') as HTMLSelectElement).value;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const nomor_telp = (document.getElementById('nomor_telp') as HTMLInputElement).value;
    const divisi_1 = div1Select.value;
    const divisi_2 = div2Select.value;
    const alasan_divisi_1 = (document.getElementById('alasan_divisi_1') as HTMLTextAreaElement).value;
    const alasan_divisi_2 = (document.getElementById('alasan_divisi_2') as HTMLTextAreaElement).value;
    const portofolio_medhum = medhumPortoInput.value;
    const bersedia_dipindah = (document.getElementById('bersedia_dipindah') as HTMLSelectElement).value;

    if (divisi_1 === divisi_2) {
      alertError.innerText = 'Division Choice 1 and Division Choice 2 cannot be the same!';
      alertError.style.display = 'block';
      return;
    }

    if ((divisi_1 === 'Medhum' || divisi_2 === 'Medhum') && !portofolio_medhum) {
      alertError.innerText = 'Please provide your MedHum portfolio URL link!';
      alertError.style.display = 'block';
      return;
    }

    if (submitBtn && btnText) {
      submitBtn.disabled = true;
      btnText.innerHTML = `Encoding files... <i class="fa-solid fa-circle-notch fa-spin" style="margin-left: 8px;"></i>`;
    }

    try {
      // Encode files to base64
      const fileKsmInput = document.getElementById('file_ksm') as HTMLInputElement;
      const fileKhsInput = document.getElementById('file_khs') as HTMLInputElement;
      const fileMlInput = document.getElementById('file_ml') as HTMLInputElement;
      const fileCvInput = document.getElementById('file_cv') as HTMLInputElement;
      const filePiInput = document.getElementById('file_pi') as HTMLInputElement;

      const [ksm, khs, ml, cv, pi] = await Promise.all([
        readFileAsBase64(fileKsmInput, 2, 'KSM'),
        readFileAsBase64(fileKhsInput, 2, 'KHS'),
        readFileAsBase64(fileMlInput, 2, 'Motivation Letter'),
        readFileAsBase64(fileCvInput, 3, 'CV'),
        readFileAsBase64(filePiInput, 2, 'Pakta Integritas')
      ]);

      if (submitBtn && btnText) {
        btnText.innerHTML = `Submitting... <i class="fa-solid fa-circle-notch fa-spin" style="margin-left: 8px;"></i>`;
      }

      const scriptURL = (import.meta.env.PUBLIC_GOOGLE_SHEET_SCRIPT_URL || '').replace(/^['"]|['"]$/g, '').trim();
      if (!scriptURL) {
        throw new Error('Google Sheets URL has not been configured in the .env file.');
      }

      const payload = {
        'Nama Lengkap': nama_lengkap,
        'NIM': nim,
        'Angkatan': angkatan,
        'Email': email,
        'Nomor Telepon': nomor_telp,
        'Divisi 1': divisi_1,
        'Alasan Divisi 1': alasan_divisi_1,
        'Divisi 2': divisi_2,
        'Alasan Divisi 2': alasan_divisi_2,
        'Portofolio MedHum': portofolio_medhum,
        'Bersedia Dipindah Divisi': bersedia_dipindah,
        'ksm': ksm,
        'khs': khs,
        'ml': ml,
        'cv': cv,
        'pi': pi
      };

      await fetch(scriptURL, {
        method: 'POST',
        headers: {
          'Content-Type': 'text/plain;charset=utf-8'
        },
        body: JSON.stringify(payload),
        mode: 'no-cors'
      });

      alertSuccess.innerText = 'Registration successfully submitted! A confirmation email has been sent to your email address.';
      alertSuccess.style.display = 'block';
      formElement.reset();
      toggleMedhumPorto();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    } catch (err: any) {
      alertError.innerText = err.message || 'Failed to submit. Please try again later.';
      alertError.style.display = 'block';
    } finally {
      if (submitBtn && btnText) {
        submitBtn.disabled = false;
        btnText.innerHTML = `Submit Registration <i class="fa-solid fa-paper-plane" style="margin-left: 8px;"></i>`;
      }
    }
  });
</script>
