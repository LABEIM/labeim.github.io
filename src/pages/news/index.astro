---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const news = await getCollection('news');
const sortedNews = news.sort((a, b) => {
  const timeA = new Date(a.data.news_date).getTime();
  const timeB = new Date(b.data.news_date).getTime();
  return isNaN(timeA) || isNaN(timeB) ? 0 : timeB - timeA;
});
---

<Layout title="News & Articles - EIM Research Lab">
  <section class="page-header" style="background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-secondary) 100%); padding: 120px 0 60px 0; text-align: center;">
    <div class="container">
      <div class="page-header-content">
        <h1 style="font-size: 3rem; margin-bottom: 15px;">News & <span class="text-gradient-cyan">Articles</span></h1>
        <p style="font-size: 1.1rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto;">Latest news, research, and announcements from the EIM Laboratory.</p>
      </div>
    </div>
  </section>

  <section class="section-padding" style="background: var(--bg-primary); min-height: 60vh;">
    <div class="container">
      {sortedNews.length === 0 ? (
        <div class="news-empty-state glass-panel" style="text-align: center; padding: 50px 0;">
          <i class="fa-regular fa-newspaper" style="font-size: 4rem; opacity: 0.3; margin-bottom: 20px;"></i>
          <h3>No News Yet</h3>
          <p>No articles or news have been published yet.</p>
        </div>
      ) : (
        <div class="news-grid" id="news-grid">
          {sortedNews.map(item => {
            let coverImg = "https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&q=80&w=600";
            if (item.data.image && item.data.image.length > 0) coverImg = item.data.image[0];

            return (
              <div class="news-card glass-panel" style="display: flex; flex-direction: column; height: 100%;">
                <div class="news-img" style="position: relative; height: 220px; overflow: hidden; border-radius: 12px 12px 0 0;">
                  <img src={coverImg} alt={`Cover ${item.data.title}`} style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease;" />
                  <span class="news-tag" style="position: absolute; top: 15px; right: 15px; background: var(--accent-cyan); color: #000; padding: 5px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: bold;">{item.data.category}</span>
                </div>
                <div class="news-content" style="padding: 25px; display: flex; flex-direction: column; flex-grow: 1;">
                  <div class="news-date" style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 12px;">
                    <i class="fa-regular fa-calendar" style="margin-right: 6px;"></i> {new Date(item.data.news_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </div>
                  <h3 style="margin-bottom: 15px; font-size: 1.25rem; line-height: 1.4;">{item.data.title}</h3>
                  <p class="news-desc" style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6; margin-bottom: 20px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                    {item.body}
                  </p>

                  <div style="margin-top: auto;">
                    <a href={`/news/${item.id}`} class="btn btn-secondary btn-read-more" style="width: 100%; padding: 10px; font-size: 0.95rem; text-align: center;">
                      Read More <i class="fa-solid fa-arrow-right" style="margin-left: 5px;"></i>
                    </a>

                    <div class="news-footer" style="margin-top: 20px; padding-top: 15px; border-top: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center; font-size: 0.9rem; color: var(--text-secondary);">
                      <span class="news-author"><i class="fa-solid fa-pen-nib" style="margin-right: 6px;"></i> {item.data.author}</span>
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>
  </section>
</Layout>
